<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Devs Chat - Rede para Desenvolvedores</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #6C63FF;
            --primary-dark: #5a52d5;
            --primary-light: #8b85ff;
            --secondary: #00D9A5;
            --dark: #1a1a2e;
            --dark-secondary: #16213e;
            --light: #f8f9fa;
            --gray: #6c757d;
            --gray-light: #e9ecef;
            --danger: #e74c3c;
            --success: #2ecc71;
            --warning: #f39c12;
            --white: #ffffff;
            --shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            --shadow-hover: 0 8px 30px rgba(0, 0, 0, 0.15);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: var(--dark);
            color: var(--white);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Login & Register Screens */
        .auth-screen {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: linear-gradient(135deg, var(--dark) 0%, var(--dark-secondary) 50%, #0f0f23 100%);
        }

        .auth-container {
            background: var(--white);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: var(--shadow-hover);
            color: var(--dark);
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .auth-logo i {
            font-size: 3rem;
            color: var(--primary);
            margin-bottom: 10px;
        }

        .auth-logo h1 {
            font-size: 1.8rem;
            color: var(--dark);
        }

        .auth-logo span {
            color: var(--primary);
        }

        .auth-logo p {
            color: var(--gray);
            font-size: 0.9rem;
            margin-top: 5px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--dark);
            font-size: 0.9rem;
        }

        .form-group input, .form-group textarea, .form-group select {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid var(--gray-light);
            border-radius: 10px;
            font-size: 1rem;
            transition: all 0.3s ease;
            background: var(--light);
        }

        .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(108, 99, 255, 0.1);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .btn {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: var(--white);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(108, 99, 255, 0.4);
        }

        .btn-secondary {
            background: var(--gray-light);
            color: var(--dark);
        }

        .btn-secondary:hover {
            background: var(--gray);
            color: var(--white);
        }

        .btn-success {
            background: linear-gradient(135deg, var(--secondary), #00b894);
            color: var(--white);
        }

        .auth-footer {
            text-align: center;
            margin-top: 25px;
            color: var(--gray);
        }

        .auth-footer a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

        .auth-footer a:hover {
            text-decoration: underline;
        }

        .divider {
            display: flex;
            align-items: center;
            margin: 25px 0;
            color: var(--gray);
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--gray-light);
        }

        .divider span {
            padding: 0 15px;
            font-size: 0.85rem;
        }

        /* Main App Layout */
        .app-container {
            display: none;
            min-height: 100vh;
        }

        .app-container.active {
            display: flex;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            background: var(--dark-secondary);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px;
            margin-bottom: 30px;
        }

        .sidebar-logo i {
            font-size: 2rem;
            color: var(--primary);
        }

        .sidebar-logo h2 {
            font-size: 1.4rem;
        }

        .sidebar-logo span {
            color: var(--secondary);
        }

        .sidebar-menu {
            flex: 1;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            border-radius: 12px;
            color: var(--gray);
            text-decoration: none;
            transition: all 0.3s ease;
            margin-bottom: 8px;
            cursor: pointer;
        }

        .menu-item:hover, .menu-item.active {
            background: var(--primary);
            color: var(--white);
        }

        .menu-item i {
            font-size: 1.2rem;
            width: 24px;
        }

        .menu-badge {
            margin-left: auto;
            background: var(--danger);
            color: var(--white);
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .sidebar-footer {
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .user-profile-mini {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.05);
        }

        .user-avatar {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.1rem;
        }

        .user-info h4 {
            font-size: 0.95rem;
        }

        .user-info p {
            font-size: 0.8rem;
            color: var(--gray);
        }

        .logout-btn {
            background: none;
            border: none;
            color: var(--gray);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .logout-btn:hover {
            background: rgba(231, 76, 60, 0.2);
            color: var(--danger);
        }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 20px;
        }

        /* Header */
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding: 20px;
            background: var(--dark-secondary);
            border-radius: 16px;
        }

        .header-title h1 {
            font-size: 1.5rem;
        }

        .header-title p {
            color: var(--gray);
            font-size: 0.9rem;
        }

        .header-actions {
            display: flex;
            gap: 15px;
        }

        .header-btn {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.05);
            border: none;
            color: var(--white);
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }

        .header-btn:hover {
            background: var(--primary);
        }

        .header-btn .badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--danger);
            width: 20px;
            height: 20px;
            border-radius: 50%;
            font-size: 0.7rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Screens */
        .screen {
            display: none;
        }

        .screen.active {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Feed Screen */
        .feed-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .feed-header h2 {
            font-size: 1.3rem;
        }

        .feed-filters {
            display: flex;
            gap: 10px;
        }

        .filter-btn {
            padding: 8px 16px;
            border-radius: 20px;
            background: var(--dark-secondary);
            border: none;
            color: var(--gray);
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.85rem;
        }

        .filter-btn.active, .filter-btn:hover {
            background: var(--primary);
            color: var(--white);
        }

        .posts-grid {
            display: grid;
            gap: 20px;
        }

        .post-card {
            background: var(--dark-secondary);
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s ease;
        }

        .post-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-hover);
        }

        .post-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }

        .post-avatar {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.1rem;
        }

        .post-user-info h3 {
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .verified-badge {
            color: var(--primary);
            font-size: 0.9rem;
        }

        .post-user-info p {
            font-size: 0.8rem;
            color: var(--gray);
        }

        .post-user-info .premium-badge {
            background: linear-gradient(135deg, #f39c12, #e74c3c);
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            margin-left: 5px;
        }

        .post-content {
            margin-bottom: 20px;
        }

        .post-content h4 {
            font-size: 1.1rem;
            margin-bottom: 10px;
        }

        .post-content p {
            color: #b0b0b0;
            line-height: 1.6;
            font-size: 0.95rem;
        }

        .post-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 15px;
        }

        .tag {
            padding: 6px 12px;
            background: rgba(108, 99, 255, 0.2);
            color: var(--primary-light);
            border-radius: 6px;
            font-size: 0.8rem;
        }

        .post-link-preview {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 12px;
            padding: 15px;
            margin-top: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .post-link-preview:hover {
            background: rgba(108, 99, 255, 0.1);
        }

        .link-icon {
            width: 50px;
            height: 50px;
            background: var(--primary);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .link-info h5 {
            font-size: 0.95rem;
            margin-bottom: 4px;
        }

        .link-info p {
            font-size: 0.8rem;
            color: var(--gray);
        }

        .post-actions {
            display: flex;
            gap: 20px;
            padding-top: 15px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .action-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: none;
            border: none;
            color: var(--gray);
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }

        .action-btn:hover {
            color: var(--primary);
        }

        .action-btn.like:hover {
            color: var(--danger);
        }

        /* Chat Screen */
        .chat-layout {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 20px;
            height: calc(100vh - 140px);
        }

        .chat-list {
            background: var(--dark-secondary);
            border-radius: 16px;
            overflow: hidden;
        }

        .chat-list-header {
            padding: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .chat-search {
            position: relative;
        }

        .chat-search input {
            width: 100%;
            padding: 12px 16px 12px 45px;
            background: rgba(255, 255, 255, 0.05);
            border: none;
            border-radius: 10px;
            color: var(--white);
            font-size: 0.9rem;
        }

        .chat-search input::placeholder {
            color: var(--gray);
        }

        .chat-search i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--gray);
        }

        .chat-list-items {
            height: calc(100% - 80px);
            overflow-y: auto;
        }

        .chat-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 15px 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            border-bottom: 1px solid rgba(255, 255, 255,1);
}

    .chat-item:hover, .chat-item.active {
        background: rgba(108, 99, 255, 0.1);
    }

    .chat-item-avatar {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        position: relative;
    }

    .online-indicator {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 12px;
        height: 12px;
        background: var(--success);
        border: 2px solid var(--dark-secondary);
        border-radius: 50%;
    }

    .chat-item-info {
        flex: 1;
        min-width: 0;
    }

    .chat-item-info h4 {
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .chat-item-info p {
        font-size: 0.8rem;
        color: var(--gray);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-item-time {
        font-size: 0.75rem;
        color: var(--gray);
    }

    .chat-item-unread {
        background: var(--primary);
        color: var(--white);
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    /* Chat Window */
    .chat-window {
        background: var(--dark-secondary);
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .chat-window-header {
        padding: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .chat-window-user {
        flex: 1;
    }

    .chat-window-user h3 {
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .chat-window-user p {
        font-size: 0.8rem;
        color: var(--success);
    }

    .chat-window-actions {
        display: flex;
        gap: 10px;
    }

    .chat-window-actions button {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.05);
        border: none;
        color: var(--white);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .chat-window-actions button:hover {
        background: var(--primary);
    }

    .chat-messages {
        flex: 1;
        padding: 20px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .message {
        display: flex;
        gap: 12px;
        max-width: 70%;
    }

    .message.sent {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .message-avatar {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        font-weight: 600;
        flex-shrink: 0;
    }

    .message-content {
        background: rgba(255, 255, 255, 0.05);
        padding: 12px 16px;
        border-radius: 16px;
        border-top-left-radius: 4px;
    }

    .message.sent .message-content {
        background: var(--primary);
        border-top-left-radius: 16px;
        border-top-right-radius: 4px;
    }

    .message-content p {
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .message-time {
        font-size: 0.7rem;
        color: var(--gray);
        margin-top: 5px;
    }

    .message.sent .message-time {
        text-align: right;
    }

    .chat-input {
        padding: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        gap: 12px;
    }

    .chat-input input {
        flex: 1;
        padding: 14px 20px;
        background: rgba(255, 255, 255, 0.05);
        border: none;
        border-radius: 12px;
        color: var(--white);
        font-size: 0.95rem;
    }

    .chat-input input::placeholder {
        color: var(--gray);
    }

    .chat-input button {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        background: var(--primary);
        border: none;
        color: var(--white);
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 1.1rem;
    }

    .chat-input button:hover {
        background: var(--primary-dark);
        transform: scale(1.05);
    }

    /* Profile Screen */
    .profile-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .profile-header {
        background: var(--dark-secondary);
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 25px;
    }

    .profile-banner {
        height: 150px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        position: relative;
    }

    .profile-premium-banner {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, #f39c12, #e74c3c);
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .profile-info-section {
        padding: 0 30px 30px;
        position: relative;
    }

    .profile-avatar-large {
        width: 120px;
        height: 120px;
        border-radius: 20px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-weight: 700;
        margin-top: -60px;
        border: 4px solid var(--dark-secondary);
        position: relative;
    }

    .profile-edit-badge {
        position: absolute;
        bottom: 10px;
        right: 10px;
        width: 35px;
        height: 35px;
        background: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .profile-name-section {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-top: 15px;
    }

    .profile-name-section h1 {
        font-size: 1.8rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .profile-actions {
        display: flex;
        gap: 10px;
    }

    .profile-actions button {
        padding: 10px 20px;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-message {
        background: var(--primary);
        color: var(--white);
    }

    .btn-follow {
        background: rgba(255, 255, 255, 0.1);
        color: var(--white);
    }

    .profile-bio {
        margin-top: 15px;
        color: #b0b0b0;
        line-height: 1.6;
    }

    .profile-stats {
        display: flex;
        gap: 40px;
        margin-top: 25px;
        padding-top: 25px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .stat-item {
        text-align: center;
    }

    .stat-item h3 {
        font-size: 1.5rem;
        color: var(--primary);
    }

    .stat-item p {
        font-size: 0.85rem;
        color: var(--gray);
    }

    .profile-skills {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
    }

    .skill-tag {
        padding: 8px 16px;
        background: rgba(108, 99, 255, 0.2);
        color: var(--primary-light);
        border-radius: 8px;
        font-size: 0.85rem;
    }

    .profile-links {
        display: flex;
        gap: 15px;
        margin-top: 20px;
    }

    .link-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        color: var(--white);
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.9rem;
    }

    .link-btn:hover {
        background: var(--primary);
    }

    /* Projects Section */
    .projects-section {
        margin-top: 25px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .section-header h2 {
