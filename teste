            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 5px;
        }

        .user-card .role {
            color: var(--primary);
            font-size: 0.9rem;
            margin-bottom: 10px;
        }

        .user-card p {
            color: var(--gray);
            font-size: 0.85rem;
            margin-bottom: 15px;
        }

        .user-card-skills {
            display: flex;
