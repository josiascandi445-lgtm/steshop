            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--primary);
            margin: 0 auto 20px;
        }

        .pricing-card h3 {
            font-size: 1.4rem;
            margin-bottom: 10px;
        }

        .pricing-card .price {
            font-size: 3rem;
            font-weight: 700;
            margin: 20px 0;
        }

        .pricing-card .price span {
            font-size: 1rem;
            color: var(--gray);
            font-weight: 400;
        }

        .pricing-features {
            list-style: none;
            text-align: left;
            margin: 30px 0;
        }

        .pricing-features li {
            padding: 12px 0;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #b0b0b0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .pricing-features li:last-child {
            border-bottom: none;
        }

        .pricing-features li i {
            color: var(--success);
        }

        .pricing-features li.disabled {
            opacity: 0.5;
        }

        .pricing-features li.disabled i {
            color: var(--danger);
        }

        .pricing-btn {
            width: 100%;
            padding: 16px;
