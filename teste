            background: linear-gradient(135deg, var(--primary), var(--secondary));
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .pricing-icon {
            width: 70px;
            height: 70px;
            background: rgba(108, 99, 255, 0.2);
            border-radius: 20px;
